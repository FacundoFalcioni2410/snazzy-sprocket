{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "ink",          "color": "#090F1A", "name": "Ink" },
        { "slug": "ink-light",    "color": "#141B27", "name": "Ink Light" },
        { "slug": "ink-mid",      "color": "#1C2325", "name": "Ink Mid" },
        { "slug": "accent",       "color": "#00D4A4", "name": "Accent" },
        { "slug": "accent-bright","color": "#00FFD0", "name": "Accent Bright" },
        { "slug": "accent-dim",   "color": "#008070", "name": "Accent Dim" },
        { "slug": "muted",        "color": "#687384", "name": "Muted" },
        { "slug": "cloud",        "color": "#C8D2D6", "name": "Cloud" },
        { "slug": "paper",        "color": "#F4F6F3", "name": "Paper" },
        { "slug": "white",        "color": "#FFFFFF", "name": "White" },
        { "slug": "black",        "color": "#000000", "name": "Black" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"DM Sans\", ui-sans-serif, system-ui, sans-serif",
          "slug": "dm-sans",
          "name": "DM Sans"
        },
        {
          "fontFamily": "Syne, ui-sans-serif, system-ui, sans-serif",
          "slug": "syne",
          "name": "Syne (Display)"
        }
      ],
      "defaultFontSizes": false,
      "fontSizes": [
        { "slug": "label",  "size": "11px", "name": "Label" },
        { "slug": "small",  "size": "14px", "name": "Small" },
        { "slug": "base",   "size": "16px", "name": "Base" },
        { "slug": "large",  "size": "18px", "name": "Large" },
        { "slug": "xl",     "size": "20px", "name": "XL" },
        { "slug": "2xl",    "size": "24px", "name": "2XL" },
        { "slug": "3xl",    "size": "32px", "name": "3XL" },
        { "slug": "4xl",    "size": "40px", "name": "4XL" },
        { "slug": "5xl",    "size": "56px", "name": "5XL" }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "%", "em"]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    }
  }
}
